@startuml family_economy
!theme plain
skinparam backgroundColor #FEFEFE
skinparam defaultFontSize 13
skinparam titleFontSize 18

title Family Economy System\n"Value creation creates opportunity.\nCharacter determines eligibility."

package "Citizenship (Not Paid)" as cit {
  [Self-care\nRespect\nEducation\nFamily participation]
}

note right of cit
  "You do these because you are
  a member of the family."
end note

package "Bounty Tiers" as tiers {
  [Tier 1: Contribution\nHousehold, Property\nOrganization] as t1
  [Tier 2: Competence\nTechnical, Creative\nAcademic, Digital] as t2
  [Tier 3: Stewardship\nBudgeting, Planning\nLeadership] as t3
  [Tier 4: Initiative\nProcess improvement\nOpportunity finding] as t4
  [Tier 5: Entrepreneurship\nProducts, Services\nVentures] as t5

  t1 -down-> t2 : Skill
  t2 -down-> t3 : Trust
  t3 -down-> t4 : Vision
  t4 -down-> t5 : Independence
}

package "Eligibility Gate" as gate {
  [Behavior Matrix\n6 traits scored 1–5\nweekly average\ndetermines tier access]
}

package "Rewards" as rewards {
  [Currency | Authority\nAccess | Responsibility\nKnowledge | Legacy]
}

gate -right-> tiers : gates access

package "Progression" as prog {
  (Allowance) -right-> (Bounties)
  (Bounties) -right-> (Projects)
  (Projects) -right-> (Entrepreneurship)
  (Entrepreneurship) -right-> (Stewardship)
}

@enduml
