@startuml heritage_identity
!theme plain
skinparam backgroundColor #FEFEFE
skinparam defaultFontSize 13
skinparam titleFontSize 18

title Heritage & Identity\n"Who Do You Think You Are?"

package "Investigation Domains" {
  [Origins\nFamily tree\nGeography\nMigration] as d1
  [Language\nFamily language\nDialects\nLost meanings] as d2
  [Faith Heritage\nTraditions\nConversions\nChurch records] as d3
  [Occupation\nFarmers, Soldiers\nCraftsmen, Engineers] as d4
  [Family Stories\nHardship, Survival\nLove, Military, Faith] as d5
  [Artifacts\nPhotos, Letters\nRecords, Recipes] as d6
  [Lessons Purchased\nSacrifices, Mistakes\nVictories, Warnings] as d7
}

package "Heritage Roles" {
  (Explorer) --> (Archivist)
  (Archivist) --> (Researcher)
  (Researcher) --> (Historian)
  (Historian) --> (Steward)
}

package "Annual Packet" {
  [One Ancestor researched\nOne Place researched\nOne Story recorded\nOne Artifact preserved\nOne Tradition understood\nOne Lesson passed forward]
}

package "Scale-Invariant Questions" {
  [Age 5: Where did Grandma live?\nAge 10: Why did we move?\nAge 15: What countries shaped us?\nAge 20: What events shaped us?\nAge 30: What do I inherit?\nAge 35: What am I leaving behind?]
}

note bottom
  "What forces, people, beliefs, sacrifices,
  languages, and stories made me who I am,
  and what part of that inheritance am I
  responsible for carrying forward?"
end note

@enduml
