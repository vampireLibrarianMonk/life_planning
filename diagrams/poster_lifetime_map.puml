@startuml poster_lifetime_map
!theme plain
skinparam backgroundColor #FEFEFE
skinparam defaultFontSize 14
skinparam titleFontSize 22
skinparam componentStyle rectangle

title Lifetime Development Map (0–35)\n\nMale PFC matures ~25–30 | Female PFC matures ~21–24\nExtending to 35 validates 5–10 years of mature-brain outcomes.

legend top left
  |= Phase |= Ages |= Brain State |
  | Foundation | 0–5 | Rapid synaptogenesis |
  | Exploration | 6–12 | Pruning & specialization |
  | Formation | 13–17 | Limbic dominance |
  | Launch | 18–24 | PFC developing |
  | Consolidation | 25–30 | PFC solidifies |
  | Stewardship | 31–35 | Full maturity |
end legend

package "Spiritual Formation" as spiritual {
  [0–5\nPrayers, Gratitude\nForgiveness] as s1
  [6–12\nScripture, History\nWorld religions] as s2
  [13–17\nTheology, Ethics\nApologetics] as s3
  [18–24\nIndependent practice\nCompeting worldviews] as s4
  [25–35\nExamined convictions\nSpiritual leadership] as s5
}

package "Financial Development" as financial {
  [0–5\n529 Plan, UTMA\nSavings jar] as f1
  [6–12\nCompound interest\nStocks/Bonds/Index] as f2
  [13–17\nSector research\nRoth IRA, DCA] as f3
  [18–24\nMarket cycles\nBehavioral finance] as f4
  [25–35\nTax harvesting\nGenerational wealth] as f5
}

package "Education & Career" as education {
  [0–5\nExpose, track\ninterests 1–5] as e1
  [6–12\nClubs, projects\nCompetitions] as e2
  [13–17\nAptitudes, shadowing\nInternships] as e3
  [18–24\nDegree / Trade /\nMilitary / Venture] as e4
  [25–35\nMastery\nMentorship] as e5
}

package "Character" as character {
  [0–5\nResponsibility\nHonesty, Kindness] as c1
  [6–12\nCourage, Discipline\nFirst case study] as c2
  [13–17\nIntegrity, MLK vs\nMalcolm X analysis] as c3
  [18–24\nResilience\nIndependent analysis] as c4
  [25–35\nWisdom, Judgment\nCharacter leadership] as c5
}

package "Life Skills" as skills {
  [0–5\nSelf-care\nRoutines] as k1
  [6–12\nCooking\nCleaning] as k2
  [13–17\nDriving, First aid\nCyber, AI literacy] as k3
  [18–24\nTaxes, Insurance\nEmergency prep] as k4
  [25–35\nEstate planning\nCommunity leadership] as k5
}

package "Heritage & Identity" as heritage {
  [0–5\nFamily stories] as h1
  [6–12\nFamily tree\nMigration map] as h2
  [13–17\nAncestor research\nFaith heritage] as h3
  [18–24\nHistorical context\nLessons from ancestors] as h4
  [25–35\nActive stewardship\nLegacy creation] as h5
}

package "Life Navigation" as navigation {
  [0–5\nObject permanence\nCause & effect\n"What happens next?"] as n1
  [6–12\nDelayed consequences\nSystem thinking\nWalls of perception] as n2
  [13–17\nNavigation model\nRadius of influence\nCourse correction cost] as n3
  [18–24\nFull framework\n3rd/4th order influence\nPresence principle] as n4
  [25–35\n5th order influence\nEternal horizon\nTeach framework] as n5
}

s1 -right-> s2
s2 -right-> s3
s3 -right-> s4
s4 -right-> s5

f1 -right-> f2
f2 -right-> f3
f3 -right-> f4
f4 -right-> f5

e1 -right-> e2
e2 -right-> e3
e3 -right-> e4
e4 -right-> e5

c1 -right-> c2
c2 -right-> c3
c3 -right-> c4
c4 -right-> c5

k1 -right-> k2
k2 -right-> k3
k3 -right-> k4
k4 -right-> k5

h1 -right-> h2
h2 -right-> h3
h3 -right-> h4
h4 -right-> h5

n1 -right-> n2
n2 -right-> n3
n3 -right-> n4
n4 -right-> n5

note bottom
  **Core Metric**: "Is this child becoming a wise, capable, kind, and independent person?"

  **Navigational Forces** (operate within all pillars):
  Position · Azimuth · Velocity · Acceleration · Current · Time · Course Correction

  **Dimensions** (degrees of freedom): Knowledge · Character · Faith · Relationships · Stewardship · Legacy
end note

@enduml
