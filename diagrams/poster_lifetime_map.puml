@startuml poster_lifetime_map
!theme plain
skinparam backgroundColor #FEFEFE
skinparam defaultFontSize 14
skinparam titleFontSize 24
skinparam noteFontSize 11
skinparam componentStyle rectangle

title Robert Flanigan — Lifetime Development Map (0–35)\n\nRationale: Male prefrontal cortex matures ~25–30 (Giedd/NIH, Lebel & Beaulieu 2011).\nFemale prefrontal cortex matures ~21–24.\nExtending to 35 ensures 5–10 years of mature-brain operation to validate outcomes.

legend top left
  |= Age Band |= Brain State |= Framework Phase |
  | 0–5 | Rapid synaptogenesis | Foundation |
  | 6–12 | Pruning & specialization | Exploration |
  | 13–17 | Limbic dominance, risk-seeking | Formation |
  | 18–24 | PFC still developing (♀ matures ~21–24) | Launch |
  | 25–30 | PFC solidifies (♂ matures ~25–30) | Consolidation |
  | 31–35 | Full executive maturity, pattern recognition | Stewardship |
end legend

package "Pillar 1: Spiritual Formation" as spiritual {
  [0–5\nFamily prayers\nGratitude\nForgiveness] as s1
  [6–12\nScripture literacy\nChurch history\nWorld religions] as s2
  [13–17\nTheology\nApologetics\nEthics\nService] as s3
  [18–24\nIndependent practice\nMission/service\nCompeting worldviews] as s4
  [25–30\nExamined convictions\nMentorship of others] as s5
  [31–35\nSpiritual leadership\nLegacy transmission] as s6
}

package "Pillar 2: Financial Development" as financial {
  [0–5\n529 Plan\nSavings jar] as f1
  [6–12\nCompound interest\nYouth account\nSpend/Save/Invest] as f2
  [13–17\nCustodial brokerage\nFirst earnings\nBudget basics] as f3
  [18–24\nRoth IRA\nIndependent budget\nCredit literacy] as f4
  [25–30\nPositive net worth\nInvestment strategy] as f5
  [31–35\nFinancial independence\ntrajectory\nGenerational planning] as f6
}

package "Pillar 3: Education & Career" as education {
  [0–5\nExpose, don't direct\nTrack interests 1–5] as e1
  [6–12\nClubs\nCompetitions\nFavorite subjects] as e2
  [13–17\nAptitudes\nJob shadowing\nInternships\nAcademic planning] as e3
  [18–24\nDegree / Trade /\nMilitary / Venture\nCertifications] as e4
  [25–30\nCareer establishment\nSpecialization\nLeadership entry] as e5
  [31–35\nMastery\nMentorship\nStrategic career moves] as e6
}

package "Pillar 4: Character" as character {
  [0–5\nResponsibility\nHonesty\nKindness] as c1
  [6–12\nCourage\nDiscipline\nCompassion\nCommitments] as c2
  [13–17\nIntegrity under\npeer pressure\nSelf-regulation] as c3
  [18–24\nAccountability\nResilience\nMoral reasoning] as c4
  [25–30\nWisdom\nJudgment\nSelf-knowledge] as c5
  [31–35\nCharacter leadership\nTeaching others\nLegacy character] as c6
}

package "Pillar 5: Life Skills" as skills {
  [0–5\nSelf-care basics\nRoutines] as k1
  [6–12\nCooking basics\nCleaning\nOrganization] as k2
  [13–17\nFull home skills\nFirst aid\nDigital literacy\nDriving] as k3
  [18–24\nTaxes\nInsurance\nLease/rent\nCybersecurity] as k4
  [25–30\nHome ownership\nLegal literacy\nFamily planning] as k5
  [31–35\nEstate planning\nAdvanced finance\nCommunity leadership] as k6
}

package "Pillar 6: Heritage & Identity" as heritage {
  [0–5\nFamily stories\nWhere did\nGrandma live?] as h1
  [6–12\nFamily tree\nMigration map\nLanguage fragments\nArtifacts] as h2
  [13–17\nAncestor research\nFaith heritage\nOccupation patterns\nHealth awareness] as h3
  [18–24\nHistorical context\nCultural inheritance\nLessons from ancestors] as h4
  [25–30\nResponsibility\nof inheritance\nPreservation role] as h5
  [31–35\nStory transmission\nActive stewardship\nLegacy creation] as h6
}

package "Family Economy System" as economy {
  [Tier 0: Citizenship\nNot paid\nFamily membership\nSelf-care, Respect,\nEducation, Spiritual] as t0
  [Tier 1: Contribution\nHousehold, Property,\nCaregiving, Admin] as t1
  [Tier 2: Competence\nTechnical, Creative,\nMechanical, Digital] as t2
  [Tier 3: Stewardship\nBudgeting, Planning,\nResource allocation] as t3
  [Tier 4: Initiative\nProcess improvement,\nOpportunity ID,\nService projects] as t4
  [Tier 5: Entrepreneurship\nProducts, Services,\nVentures, Innovation] as t5
}

