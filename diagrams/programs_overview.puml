@startuml programs_overview
!theme plain
skinparam backgroundColor #FEFEFE
skinparam defaultFontSize 11

title Programs & Structured Tracks (8)

package "Programs" {
  rectangle "🎖️ Military Preparation" as mil #F5F5F5 {
    (Phase 1: Orientation) as p1
    (Phase 2: Knowledge) as p2
    (Phase 3: Standards) as p3
    (Phase 4: Technical) as p4
    (Phase 5: Decision) as p5
    p1 --> p2
    p2 --> p3
    p3 --> p4
    p4 --> p5
  }

  rectangle "⛪ Catholic Practices" as cath #F5F5FF {
    (Weekly: Mass, Confession, Fast, Prayer) as cw
    (Periodic: Rosary, Stations, Adoration) as cp
    (Service: Altar, Mercy, Retreat) as cs
    (Legendary: 4×4×14×48) as cl
    cw --> cp
    cp --> cs
    cs --> cl
  }

  rectangle "📚 Research Bounties" as res #FFFFF5 {
    (Design Templates) as rt
    (Saint Fact Sheets) as rs
    (Paradox Fact Sheets) as rp
    (Effect Fact Sheets) as re
    rt --> rs
    rt --> rp
    rt --> re
  }

  rectangle "💒 Marriage Prep (Catholic)" as marc #FFF5FF {
    (Discernment → FOCCUS → NFP → Retreat → Sacrament) as mcc
  }

  rectangle "💍 Marriage Prep (Secular)" as mars #FFF5FF {
    (Readiness → 100 Questions → Frameworks → Constitution) as msc
  }

  rectangle "🚗 Earn Your Car" as car #F5FFF5 {
    (Phase 1: Vehicle Literacy) as c1
    (Phase 2: Care & Maintenance) as c2
    (Phase 3: Legal Preparation) as c3
    (Phase 4: Licensure) as c4
    (7-Year PMCS Streak → Vehicle) as c5
    c1 --> c2
    c2 --> c3
    c3 --> c4
    c4 --> c5
  }

  rectangle "💪 Physical Fitness" as fit #F0FFF0 {
    (Weekly Activity + Quarterly Assessment) as f1
    (Sport Milestones) as f2
    (Advanced Fitness) as f3
    (Lifetime Habit Established) as f4
    f1 --> f2
    f2 --> f3
    f3 --> f4
  }

  rectangle "🏙️ 311 Civic Service" as civic #F5F5FF {
    (Phase 1: Awareness) as v1
    (Phase 2: Engagement) as v2
    (Phase 3: Service) as v3
    (Phase 4: Leadership) as v4
    v1 --> v2
    v2 --> v3
    v3 --> v4
  }
}

note bottom of mil
  Ironforged: $10,000
end note

note bottom of marc
  Covenant: $15,000
end note

note bottom of mars
  Covenant: $15,000
end note

note bottom of car
  Ooh Shiny: Vehicle ($25K cap)
end note

note bottom of fit
  Platinum: $500
end note

note bottom of civic
  Diamond: $500
end note
@enduml
