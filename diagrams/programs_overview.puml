@startuml programs_overview
!theme plain
skinparam backgroundColor #FEFEFE
skinparam defaultFontSize 11

title Programs & Structured Tracks (10)

package "Programs" {
  rectangle "🎖️ Military Preparation" as mil #F5F5F5 {
    (Phase 1: Orientation) as p1
    (Phase 2: Knowledge) as p2
    (Phase 3: Standards) as p3
    (Phase 4: Technical) as p4
    (Phase 5: Decision) as p5
    p1 --> p2
    p2 --> p3
    p3 --> p4
    p4 --> p5
  }

  rectangle "⛪ Catholic Practices" as cath #F5F5FF {
    (Weekly: Mass, Confession, Prayer) as cw
    (Periodic: Season, Saints, CST) as cp
    (Service: Mercy, Formation) as cs
    (Legendary: 48 Consecutive Weeks) as cl
    cw --> cp
    cp --> cs
    cs --> cl
  }

  rectangle "🧠 Formation Study" as form #FFFFF5 {
    (Life Cards & Belonging Maps) as fl
    (Systems Maintenance) as fs
    (Breadth of Belonging) as fb
    fl --> fs
    fl --> fb
  }

  rectangle "💒 Marriage Prep (Catholic)" as marc #FFF5FF {
    (Discernment → Pre-Cana → NFP → Sponsor → Sacrament) as mcc
  }

  rectangle "💍 Marriage Prep (Secular)" as mars #FFF5FF {
    (Self-Assessment → 100 Questions → Legal/Financial → Constitution) as msc
  }

  rectangle "🚗 Earn Your Car" as car #F5FFF5 {
    (Phase 1: Vehicle Literacy) as c1
    (Phase 2: Care & Maintenance + PMCS) as c2
    (Phase 3: Legal Prep & Permit) as c3
    (Phase 4: Licensure) as c4
    (Early Match Path OR Full 7-Year Streak) as c5
    c1 --> c2
    c2 --> c3
    c3 --> c4
    c4 --> c5
  }

  rectangle "💪 Physical Fitness" as fit #F0FFF0 {
    (Baseline + Weekly Activity) as f1
    (Quarterly Assessment + Sport) as f2
    (Training Program Design) as f3
    (Sustained Lifestyle: 6 Months) as f4
    f1 --> f2
    f2 --> f3
    f3 --> f4
  }

  rectangle "🏙️ 311 Civic Service" as civic #F5F5FF {
    (Phase 1: Awareness) as v1
    (Phase 2: Engagement) as v2
    (Phase 3: Service) as v3
    (Phase 4: Leadership) as v4
    v1 --> v2
    v2 --> v3
    v3 --> v4
  }

  rectangle "⚖️ Jury Duty & Case Review" as jury #FFF5F5 {
    (Fairness & Evidence) as j1
    (Cases, Sources & Narrative) as j2
    (Legal Standards & Institutional Trust) as j3
    (Capstone & Teaching) as j4
    j1 --> j2
    j2 --> j3
    j3 --> j4
  }

  rectangle "🗳️ Civic Chain of Command" as chain #F5FFF5 {
    (Phase 1: Name the Layers) as cc1
    (Phase 2: Full Map) as cc2
    (Phase 3: Elections & Parties) as cc3
    (Phase 4: Deep Dives & Capstones) as cc4
    (Phase 5: Election Readiness) as cc5
    cc1 --> cc2
    cc2 --> cc3
    cc3 --> cc4
    cc4 --> cc5
  }
}

note bottom of mil
  Ironforged: $2,000
end note

note bottom of cath
  Legendary: $2,000
end note

note bottom of marc
  Covenant: $10,000
end note

note bottom of mars
  Covenant: $10,000
end note

note bottom of car
  Ooh Shiny: $15K transportation budget
  (vehicle + 2yr insurance)
end note

note bottom of fit
  Platinum: $500
end note

note bottom of civic
  Diamond: $500
end note

note bottom of jury
  Per-bounty (no capstone)
end note

note bottom of chain
  Diamond: $500
end note
@enduml
